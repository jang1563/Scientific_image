{
  "name": "@jang1563/scientific-image",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "description": "Local-first scientific visual communication editor with a structured scene graph, exports, API, and MCP surface.",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/jang1563/Scientific_image#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jang1563/Scientific_image.git"
  },
  "bugs": {
    "url": "https://github.com/jang1563/Scientific_image/issues"
  },
  "keywords": [
    "mcp",
    "scientific-visualization",
    "bioinformatics",
    "biology",
    "svg",
    "slides",
    "agent",
    "local-first"
  ],
  "bin": {
    "scientific-image-mcp": "bin/scientific-image-mcp.js",
    "scientific-image-mcp-doctor": "bin/scientific-image-mcp-doctor.js"
  },
  "exports": {
    ".": "./dist/packages/agent/src/index.js",
    "./assets": "./dist/packages/assets/src/index.js",
    "./scene": "./dist/packages/scene/src/index.js",
    "./export": "./dist/packages/export/src/index.js",
    "./mcp/server": "./dist/packages/mcp/src/server.js",
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "dist/",
    "apps/api/src/",
    "apps/web/",
    "packages/",
    "scripts/agent-acceptance-smoke.ts",
    "scripts/build-npm-package.ts",
    "scripts/generate-public-examples.ts",
    "scripts/npm-package-readiness.ts",
    "scripts/portfolio-metrics.ts",
    "scripts/public-demo-visual-qa.ts",
    "scripts/public-readiness-audit.ts",
    "scripts/reviewer-status.ts",
    "scripts/serve-static.ts",
    "docs/",
    ".mcp.json.example",
    ".mcp.npm.example.json",
    "codex.mcp.example.toml",
    "codex.npm.example.toml",
    "tsconfig.json",
    "tsconfig.npm.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "node --test tests/*.test.ts",
    "status:reviewer": "node scripts/reviewer-status.ts",
    "metrics": "node scripts/portfolio-metrics.ts",
    "agent:smoke": "node scripts/agent-acceptance-smoke.ts",
    "examples:public": "node scripts/generate-public-examples.ts",
    "qa:public-demos": "node scripts/public-demo-visual-qa.ts",
    "public:audit": "node scripts/public-readiness-audit.ts",
    "build:npm": "node scripts/build-npm-package.ts",
    "package:check": "node scripts/npm-package-readiness.ts",
    "pack:dry-run": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run --access public",
    "prepack": "node scripts/build-npm-package.ts",
    "prepublishOnly": "node scripts/npm-package-readiness.ts && node scripts/public-readiness-audit.ts",
    "dev:web": "node scripts/serve-static.ts apps/web 4173",
    "dev:api": "node apps/api/src/server.ts",
    "mcp": "node bin/scientific-image-mcp.js",
    "mcp:doctor": "node bin/scientific-image-mcp-doctor.js",
    "mcp:help": "node bin/scientific-image-mcp.js --help"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24"
  }
}
